COMPOSE_PROJECT_NAME=umwelt-compliance

POSTGRES_DB=umwelt
POSTGRES_USER=umwelt
POSTGRES_PASSWORD=change-this-db-password

JWT_SECRET=change-this-jwt-secret-to-a-long-random-value
AUTH_DEMO_PASSWORD=demo123

APP_ORIGIN=https://umwelt-app.kunde.local
PUBLIC_API_BASE_URL=https://umwelt-app.kunde.local/api

HTTP_PORT=80

MAX_UPLOAD_BYTES=10485760
PROOF_UPLOAD_RATE_LIMIT_WINDOW_SEC=60
PROOF_UPLOAD_RATE_LIMIT_MAX=10
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp
